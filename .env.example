# Optional: hostnames allowed for dev when opening the app via LAN (e.g. 10.25.31.21), comma-separated
# NEXT_DEV_EXTRA_ORIGINS=10.25.31.21

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Min 16 characters; used to sign the httpOnly gallery session cookie
SESSION_SECRET=
# Optional (server only): use when RLS blocks the anon key from reading `student_access`
# SUPABASE_SERVICE_ROLE_KEY=

R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET_NAME=

# Login page “reach out” form — https://resend.com (API key + verified sender domain, or onboarding@resend.dev for tests)
RESEND_API_KEY=
# Inbox where contact submissions are delivered
CONTACT_TO_EMAIL=
# Verified sender in Resend, e.g. Studio Gallery <onboarding@resend.dev>
CONTACT_FROM_EMAIL=
